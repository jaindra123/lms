{{!
    @template theme_iiidem2/pages/enrol-preview

    Public course preview on /enrol/index.php (no login required).
}}
{{> theme_iiidem2/navbar }}

<main class="iiidem-marketing-page iiidem-enrol-preview-page">

    {{> theme_iiidem2/course/hero }}

    {{> theme_iiidem2/course/summary }}

    {{#hasinstructors}}
    {{> theme_iiidem2/course/instructors }}
    {{/hasinstructors}}

    <section class="iiidem-course-detail-cta py-4">
        <div class="container">
            <div class="d-flex flex-wrap gap-3 align-items-center justify-content-between">
                <p class="mb-0 text-muted">{{#str}}coursedetailintro, theme_iiidem2{{/str}}</p>
                <div class="d-flex flex-wrap gap-2">
                    <a href="{{loginurl}}" class="btn btn-primary">{{#str}}coursedetaillogin, theme_iiidem2{{/str}}</a>
                    <a href="{{{ config.wwwroot }}}" class="btn btn-outline-secondary">{{#str}}home{{/str}}</a>
                </div>
            </div>
        </div>
    </section>

</main>

{{> theme_iiidem2/page_end }}
