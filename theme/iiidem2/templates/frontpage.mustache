{{!
    @template theme_iiidem2/frontpage

    Site home: hero slider, features, about, courses, CTA, footer.
}}
{{> theme_iiidem2/head }}
<body {{{ bodyattributes }}}>
{{> core/local/toast/wrapper}}
{{{ output.standard_top_of_body_html }}}
{{> theme_iiidem2/navbar }}

<main class="iiidem-frontpage" id="iiidem-frontpage-main">

    {{> theme_iiidem2/slider }}

    <section class="iiidem-features" aria-labelledby="iiidem-features-heading">
        <div class="container">
            <h2 id="iiidem-features-heading" class="visually-hidden">{{#str}}home{{/str}}</h2>
            <div class="row g-4">
                <div class="col-md-4">
                    <div class="iiidem-feature-card">
                        <div class="iiidem-feature-card__icon" aria-hidden="true">
                            <i class="fa-solid fa-graduation-cap"></i>
                        </div>
                        <h3 class="iiidem-feature-card__title">Certification Programs</h3>
                        <p class="iiidem-feature-card__text">Structured courses with assessments, progress tracking, and credentials.</p>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="iiidem-feature-card">
                        <div class="iiidem-feature-card__icon" aria-hidden="true">
                            <i class="fa-solid fa-video"></i>
                        </div>
                        <h3 class="iiidem-feature-card__title">Live &amp; Recorded Learning</h3>
                        <p class="iiidem-feature-card__text">Join live sessions or learn at your own pace with rich multimedia content.</p>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="iiidem-feature-card">
                        <div class="iiidem-feature-card__icon" aria-hidden="true">
                            <i class="fa-solid fa-certificate"></i>
                        </div>
                        <h3 class="iiidem-feature-card__title">Track Your Progress</h3>
                        <p class="iiidem-feature-card__text">Dashboards, completion status, and certificates in one place.</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section class="iiidem-about-section" id="about-iiidem">
        {{> theme_iiidem2/about }}
    </section>

    <section class="advisors-section-idea" id="about-idea">
        {{{aboutideahtml}}}
    </section>

    {{#hasadvisors}}
    {{> theme_iiidem2/program_governance }}
    {{/hasadvisors}}

    {{#hascourses}}
    <section class="iiidem-courses-section" id="courses">
        <div class="container">
            <div class="iiidem-section-header text-center">
              
                <h2 class="iiidem-section-header__title">Explore Our Courses</h2>
                <p class="iiidem-section-header__lead">Browse certification and training programs designed for election professionals.</p>
            </div>
            {{> theme_iiidem2/courses }}
        </div>
    </section>
    {{/hascourses}}

    <section class="iiidem-cta">
        <div class="container">
            <div class="iiidem-cta__inner text-center">
                <h2 class="iiidem-cta__title">Ready to start learning?</h2>
                <p class="iiidem-cta__text">Sign in to access your courses, live classes, and certificates.</p>
                <div class="iiidem-cta__actions">
                    {{#isrealuser}}
                        <a href="{{coursesurl}}" class="btn btn-light btn-lg iiidem-btn">My courses</a>
                    {{/isrealuser}}
                    {{^isrealuser}}
                        <a href="{{registerurl}}" class="btn btn-light btn-lg iiidem-btn">Create account</a>
                        <a href="{{loginurl}}" class="btn btn-outline-light btn-lg iiidem-btn iiidem-btn--outline">Login to portal</a>
                        <a href="{{coursesurl}}" class="btn btn-outline-light btn-lg iiidem-btn iiidem-btn--outline">Browse courses</a>
                    {{/isrealuser}}
                </div>
            </div>
        </div>
    </section>

</main>
