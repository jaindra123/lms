{{!
    @template theme_iiidem2/secure

    iiidem2 secure layout template.

    Context variables required for this template:
    * sitename - The name of the site
    * output - The core renderer for the page

      Example context (json):
    {
        "sitename": "Moodle",
        "output": {
            "doctype": "<!DOCTYPE html>",
            "page_title": "Test page",
            "favicon": "favicon.ico",
            "main_content": "<h1>Headings make html validators happier</h1>"
         }
    }
}}
{{> theme_iiidem2/head }}

<body {{{ bodyattributes }}}>
{{> core/local/toast/wrapper}}

<div id="page-wrapper">

    {{{ output.standard_top_of_body_html }}}

    {{>theme_iiidem2/navbar-secure}}

    <div id="page" class="container-fluid">
        {{! Secured full header }}

        <header id="page-header" class="row">
            <div class="col-12 py-3">
                <div class="page-context-header">
                    <div class="page-header-headings">
                        {{{ output.page_heading }}}
                    </div>
                </div>
            </div>
        </header>

        <div id="page-content" class="row">
            <div id="region-main-box" class="col-12">
                <div id="region-main" {{#hasblocks}}class="has-blocks"{{/hasblocks}}>

                    {{{ output.course_content_header }}}
                    {{#headercontent}}
                        {{> core/activity_header }}
                    {{/headercontent}}
                    {{{ output.main_content }}}
                    {{{ output.course_content_footer }}}

                </div>
                {{#hasblocks}}
                <div data-region="blocks-column">
                    {{{ sidepreblocks }}}
                </div>
                {{/hasblocks}}
            </div>
        </div>
    </div>
    {{> theme_iiidem2/page_end }}
</div>

{{{ output.standard_end_of_body_html }}}

</body>
</html>
{{#js}}
M.util.js_pending('theme_iiidem2/loader');
require(['theme_iiidem2/loader'], function() {
    M.util.js_complete('theme_iiidem2/loader');
});
{{/js}}
