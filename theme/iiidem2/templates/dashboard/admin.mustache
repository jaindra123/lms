<div class="row g-4 admin-dashboard">
    <div class="col-md-3">
        <div class="card h-100 shadow-sm border-dark">
            <div class="card-body">
                <h2 class="h5 card-title">{{#str}}dashboardusers, theme_iiidem2{{/str}}</h2>
                <p class="card-text text-muted">{{#str}}dashboardusers_desc, theme_iiidem2{{/str}}</p>
                <a class="btn btn-dark" href="{{usersurl}}">{{#str}}view{{/str}}</a>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card h-100 shadow-sm">
            <div class="card-body">
                <h2 class="h5 card-title">{{#str}}dashboardcourses, theme_iiidem2{{/str}}</h2>
                <p class="card-text text-muted">{{#str}}dashboardcourses_desc, theme_iiidem2{{/str}}</p>
                <a class="btn btn-primary" href="{{coursesurl}}">{{#str}}view{{/str}}</a>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card h-100 shadow-sm">
            <div class="card-body">
                <h2 class="h5 card-title">{{#str}}dashboardsiteadmin, theme_iiidem2{{/str}}</h2>
                <p class="card-text text-muted">{{#str}}dashboardsiteadmin_desc, theme_iiidem2{{/str}}</p>
                <a class="btn btn-outline-primary" href="{{siteadminurl}}">{{#str}}view{{/str}}</a>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card h-100 shadow-sm">
            <div class="card-body">
                <h2 class="h5 card-title">{{#str}}dashboardreports, theme_iiidem2{{/str}}</h2>
                <p class="card-text text-muted">{{#str}}dashboardreports_desc, theme_iiidem2{{/str}}</p>
                <a class="btn btn-outline-secondary" href="{{reportsurl}}">{{#str}}view{{/str}}</a>
            </div>
        </div>
    </div>
</div>

<section class="row g-4 mt-2 admin-dashboard-calendar">
    <div class="col-12">
        {{> theme_iiidem2/dashboard/calendar_panel }}
    </div>
</section>
