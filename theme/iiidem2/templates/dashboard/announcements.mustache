{{!
    @template theme_iiidem2/dashboard/announcements

    Recent announcements from enrolled courses (forum type: news).
}}
<section class="iiidem-dashboard-announcements mb-4" aria-labelledby="iiidem-announcements-heading">
    <div class="card shadow-sm">
        <div class="card-header bg-white border-bottom">
            <h2 id="iiidem-announcements-heading" class="h5 mb-0">{{#str}}dashboardannouncements, theme_iiidem2{{/str}}</h2>
        </div>
        <div class="card-body p-0">
            {{#hasannouncements}}
            <ul class="list-group list-group-flush iiidem-announcement-list">
                {{#announcements}}
                <li class="list-group-item iiidem-announcement-item">
                    <div class="d-flex flex-wrap justify-content-between align-items-start gap-2 mb-1">
                        <span class="badge bg-light text-dark border">{{coursefullname}}</span>
                        <time class="text-muted small">{{date}}</time>
                    </div>
                    <h3 class="h6 mb-1">
                        <a href="{{{url}}}">{{subject}}</a>
                    </h3>
                    {{#hasexcerpt}}
                    <p class="text-muted small mb-0">{{excerpt}}</p>
                    {{/hasexcerpt}}
                </li>
                {{/announcements}}
            </ul>
            {{/hasannouncements}}
            {{^hasannouncements}}
            <p class="text-muted mb-0 p-3">{{#str}}dashboardannouncements_none, theme_iiidem2{{/str}}</p>
            {{/hasannouncements}}
        </div>
    </div>
</section>
