{{!
    @template theme_iiidem2/dashboard/teacher

    Teacher dashboard: courses, actions, pending work, performance, analytics, schedule, communication.
}}
<div class="iiidem-teacher-dashboard">

    <div class="row g-4 mb-4">
        <div class="col-lg-7">
            <section class="iiidem-dash-panel card shadow-sm h-100">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h2 class="h5 mb-0">📘 {{#str}}dashboardteachercourses, theme_iiidem2{{/str}}</h2>
                    <a class="btn btn-sm btn-outline-primary" href="{{coursesurl}}">{{#str}}viewall, theme_iiidem2{{/str}}</a>
                </div>
                <div class="card-body">
                    {{#hasteachercourses}}
                    <div class="row g-3">
                        {{#teachercourses}}
                        <div class="col-md-6">
                            <article class="iiidem-course-card border rounded overflow-hidden h-100">
                                <div class="iiidem-course-card__image" style="background-image:url('{{{courseimage}}}')"></div>
                                <div class="p-3">
                                    <h3 class="h6 mb-1">{{fullname}}</h3>
                                    <p class="small text-muted mb-2">{{studentcountlabel}}</p>
                                    <div class="d-flex flex-wrap gap-2">
                                        <a class="btn btn-primary btn-sm" href="{{viewurl}}">{{#str}}entercourse, theme_iiidem2{{/str}}</a>
                                        <a class="btn btn-outline-secondary btn-sm" href="{{editurl}}">{{#str}}edit{{/str}}</a>
                                        <a class="btn btn-outline-primary btn-sm" href="{{participantsurl}}">{{#str}}dashboardteacherstudentslink, theme_iiidem2{{/str}}</a>
                                    </div>
                                </div>
                            </article>
                        </div>
                        {{/teachercourses}}
                    </div>
                    {{/hasteachercourses}}
                    {{^hasteachercourses}}
                    <p class="text-muted mb-0">{{#str}}dashboardteachernocourses, theme_iiidem2{{/str}}</p>
                    {{/hasteachercourses}}
                </div>
            </section>
        </div>

        <div class="col-lg-5">
            <section class="iiidem-dash-panel card shadow-sm h-100">
                <div class="card-header">
                    <h2 class="h5 mb-0">⚡ {{#str}}dashboardteacherquickactions, theme_iiidem2{{/str}}</h2>
                </div>
                <div class="card-body">
                    {{#hasquickactions}}
                    <div class="row g-2">
                        {{#quickactions}}
                        <div class="col-6">
                            <a href="{{{url}}}" class="iiidem-quick-action btn btn-outline-primary w-100 h-100 py-3">
                                <span class="fa {{icon}} d-block mb-2" aria-hidden="true"></span>
                                <span class="small">{{label}}</span>
                            </a>
                        </div>
                        {{/quickactions}}
                    </div>
                    {{/hasquickactions}}
                </div>
            </section>
        </div>
    </div>

    <div class="row g-4 mb-4">
        <div class="col-lg-6">
            <section class="iiidem-dash-panel card shadow-sm h-100">
                <div class="card-header">
                    <h2 class="h5 mb-0">📝 {{#str}}dashboardteacherpending, theme_iiidem2{{/str}}</h2>
                </div>
                <div class="card-body p-0">
                    {{#haspendingtasks}}
                    <ul class="list-group list-group-flush iiidem-dash-list">
                        {{#pendingtasks}}
                        <li class="list-group-item d-flex flex-wrap justify-content-between align-items-center gap-2">
                            <div>
                                <span class="badge bg-warning text-dark me-1">{{typelabel}}</span>
                                <strong>{{title}}</strong>
                                <div class="small text-muted">{{coursefullname}} · {{date}}</div>
                            </div>
                            <a class="btn btn-sm btn-primary" href="{{{url}}}">{{#str}}dashboardteachergrade, theme_iiidem2{{/str}}</a>
                        </li>
                        {{/pendingtasks}}
                    </ul>
                    {{/haspendingtasks}}
                    {{^haspendingtasks}}
                    <p class="text-muted p-3 mb-0">{{#str}}dashboardteachernopending, theme_iiidem2{{/str}}</p>
                    {{/haspendingtasks}}
                </div>
            </section>
        </div>

        <div class="col-lg-6">
            <section class="iiidem-dash-panel card shadow-sm h-100">
                <div class="card-header">
                    <h2 class="h5 mb-0">🧑‍🎓 {{#str}}dashboardteacherperformance, theme_iiidem2{{/str}}</h2>
                </div>
                <div class="card-body p-0">
                    {{#hasstudentperformance}}
                    <ul class="list-group list-group-flush iiidem-dash-list">
                        {{#studentperformance}}
                        <li class="list-group-item">
                            <div class="d-flex justify-content-between align-items-start mb-2">
                                <strong>{{coursename}}</strong>
                                <span class="badge bg-light text-dark border">{{studentcountlabel}}</span>
                            </div>
                            {{#hascompletion}}
                            <div class="progress mb-2" style="height:8px;">
                                <div class="progress-bar bg-success" role="progressbar" style="width: {{completion}}%;" aria-valuenow="{{completion}}" aria-valuemin="0" aria-valuemax="100"></div>
                            </div>
                            <p class="small text-muted mb-2">{{completionlabel}}</p>
                            {{/hascompletion}}
                            {{^hascompletion}}
                            <p class="small text-muted mb-2">{{completionlabel}}</p>
                            {{/hascompletion}}
                            <div class="d-flex flex-wrap gap-2">
                                <a class="btn btn-sm btn-outline-primary" href="{{participantsurl}}">{{#str}}dashboardteacherstudentslink, theme_iiidem2{{/str}}</a>
                                <a class="btn btn-sm btn-outline-secondary" href="{{gradebookurl}}">{{#str}}dashboardteachergradebook, theme_iiidem2{{/str}}</a>
                                {{#hasattendance}}
                                <a class="btn btn-sm btn-outline-secondary" href="{{attendanceurl}}">{{#str}}dashboardteacherattendance, theme_iiidem2{{/str}}</a>
                                {{/hasattendance}}
                            </div>
                        </li>
                        {{/studentperformance}}
                    </ul>
                    {{/hasstudentperformance}}
                    {{^hasstudentperformance}}
                    <p class="text-muted p-3 mb-0">{{#str}}dashboardteachernocourses, theme_iiidem2{{/str}}</p>
                    {{/hasstudentperformance}}
                </div>
            </section>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-lg-6">
            <section class="iiidem-dash-panel card shadow-sm h-100">
                <div class="card-header">
                    <h2 class="h5 mb-0">📊 {{#str}}dashboardteacheranalytics, theme_iiidem2{{/str}}</h2>
                </div>
                <div class="card-body">
                    {{#hasanalytics}}
                    <div class="row g-3">
                        {{#analytics}}
                        <div class="col-6">
                            <div class="iiidem-stat-card text-center p-3 rounded border h-100">
                                <div class="iiidem-stat-card__icon mb-2"><span class="fa {{icon}}" aria-hidden="true"></span></div>
                                <div class="iiidem-stat-card__value h4 mb-0">{{value}}</div>
                                <div class="iiidem-stat-card__label small text-muted">{{label}}</div>
                            </div>
                        </div>
                        {{/analytics}}
                    </div>
                    {{/hasanalytics}}
                </div>
            </section>
        </div>

        <div class="col-lg-6">
            <section class="iiidem-dash-panel card shadow-sm h-100">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h2 class="h5 mb-0">📅 {{#str}}dashboardteacherschedule, theme_iiidem2{{/str}}</h2>
                    <a class="btn btn-sm btn-link" href="{{{calendarurl}}}">{{#str}}calendar, core_calendar{{/str}}</a>
                </div>
                <div class="card-body p-0">
                    {{#hasschedule}}
                    <ul class="list-group list-group-flush iiidem-dash-list">
                        {{#schedule}}
                        <li class="list-group-item">
                            <span class="badge bg-secondary me-2">{{typelabel}}</span>
                            <a href="{{{url}}}" class="fw-semibold">{{title}}</a>
                            <div class="small text-muted">{{coursefullname}} · {{date}}</div>
                        </li>
                        {{/schedule}}
                    </ul>
                    {{/hasschedule}}
                    {{^hasschedule}}
                    <p class="text-muted p-3 mb-0">{{#str}}dashboardteachernoschedule, theme_iiidem2{{/str}}</p>
                    {{/hasschedule}}
                </div>
            </section>
        </div>
    </div>

    <div class="row g-4 mt-0">
        <div class="col-12">
            <section class="iiidem-dash-panel card shadow-sm">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h2 class="h5 mb-0">💬 {{#str}}dashboardteachercommunication, theme_iiidem2{{/str}}</h2>
                    <a class="btn btn-sm btn-outline-primary" href="{{{messagesurl}}}">{{#str}}dashboardteacheractionmessages, theme_iiidem2{{/str}}</a>
                </div>
                <div class="card-body p-0">
                    {{#hascommunications}}
                    <ul class="list-group list-group-flush iiidem-dash-list">
                        {{#communications}}
                        <li class="list-group-item">
                            <span class="fa {{icon}} me-2 text-primary" aria-hidden="true"></span>
                            <a href="{{{url}}}">{{title}}</a>
                            <div class="small text-muted">{{meta}}</div>
                        </li>
                        {{/communications}}
                    </ul>
                    {{/hascommunications}}
                </div>
            </section>
        </div>
    </div>

</div>
