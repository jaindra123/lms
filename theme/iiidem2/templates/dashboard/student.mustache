{{!
    @template theme_iiidem2/dashboard/student

    Student dashboard: courses, progress, upcoming, live classes, notifications, activity.
}}
<div class="iiidem-student-dashboard">

    <div class="row g-4 mb-4">
        <div class="col-lg-7">
            <section class="iiidem-dash-panel card shadow-sm h-100">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h2 class="h5 mb-0">📚 {{#str}}dashboardmycourses, theme_iiidem2{{/str}}</h2>
                    <a class="btn btn-sm btn-outline-primary" href="{{mycoursesurl}}">{{#str}}viewall, theme_iiidem2{{/str}}</a>
                </div>
                <div class="card-body">
                    {{#hasstudentcourses}}
                    <div class="row g-3">
                        {{#studentcourses}}
                        <div class="col-md-6">
                            <article class="iiidem-course-card border rounded overflow-hidden h-100">
                                <div class="iiidem-course-card__image" style="background-image:url('{{{courseimage}}}')"></div>
                                <div class="p-3">
                                    <h3 class="h6 mb-1">{{fullname}}</h3>
                                    {{#hasprogress}}
                                    <div class="progress mb-2" style="height:8px;">
                                        <div class="progress-bar bg-primary" role="progressbar" style="width: {{progress}}%;" aria-valuenow="{{progress}}" aria-valuemin="0" aria-valuemax="100"></div>
                                    </div>
                                    <p class="small text-muted mb-2">{{progresslabel}}</p>
                                    {{/hasprogress}}
                                    {{^hasprogress}}
                                    <p class="small text-muted mb-2">{{progresslabel}}</p>
                                    {{/hasprogress}}
                                    <a class="btn btn-primary btn-sm" href="{{viewurl}}">{{#str}}dashboardcontinue, theme_iiidem2{{/str}}</a>
                                </div>
                            </article>
                        </div>
                        {{/studentcourses}}
                    </div>
                    {{/hasstudentcourses}}
                    {{^hasstudentcourses}}
                    <p class="text-muted mb-0">{{#str}}dashboardnocourses, theme_iiidem2{{/str}}</p>
                    {{/hasstudentcourses}}
                </div>
            </section>
        </div>

        <div class="col-lg-5">
            <section class="iiidem-dash-panel card shadow-sm h-100">
                <div class="card-header">
                    <h2 class="h5 mb-0">📊 {{#str}}dashboardlearningprogress, theme_iiidem2{{/str}}</h2>
                </div>
                <div class="card-body">
                    {{#hasprogresscards}}
                    <div class="row g-3">
                        {{#progresscards}}
                        <div class="col-6">
                            <div class="iiidem-stat-card text-center p-3 rounded border h-100">
                                <div class="iiidem-stat-card__icon mb-2"><span class="fa {{icon}}" aria-hidden="true"></span></div>
                                <div class="iiidem-stat-card__value h4 mb-0">{{value}}</div>
                                <div class="iiidem-stat-card__label small text-muted">{{label}}</div>
                            </div>
                        </div>
                        {{/progresscards}}
                    </div>
                    {{#badgesurl}}
                    <p class="small mt-3 mb-0"><a href="{{{badgesurl}}}">{{#str}}dashboardviewbadges, theme_iiidem2{{/str}}</a></p>
                    {{/badgesurl}}
                    {{/hasprogresscards}}
                </div>
            </section>
        </div>
    </div>

    <div class="row g-4 mb-4">
        <div class="col-lg-6">
            <section class="iiidem-dash-panel card shadow-sm h-100">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h2 class="h5 mb-0">⏰ {{#str}}dashboardupcoming, theme_iiidem2{{/str}}</h2>
                    <a class="btn btn-sm btn-link" href="{{{calendarurl}}}">{{#str}}calendar, core_calendar{{/str}}</a>
                </div>
                <div class="card-body p-0">
                    {{#hasupcoming}}
                    <ul class="list-group list-group-flush iiidem-dash-list">
                        {{#upcoming}}
                        <li class="list-group-item">
                            <span class="badge bg-secondary me-2">{{typelabel}}</span>
                            <a href="{{{url}}}" class="fw-semibold">{{title}}</a>
                            <div class="small text-muted">{{coursefullname}} · {{date}}</div>
                        </li>
                        {{/upcoming}}
                    </ul>
                    {{/hasupcoming}}
                    {{^hasupcoming}}
                    <p class="text-muted p-3 mb-0">{{#str}}dashboardnoupcoming, theme_iiidem2{{/str}}</p>
                    {{/hasupcoming}}
                </div>
            </section>
        </div>

        <div class="col-lg-6">
            <section class="iiidem-dash-panel card shadow-sm h-100">
                <div class="card-header">
                    <h2 class="h5 mb-0">🎥 {{#str}}dashboardliveclasses, theme_iiidem2{{/str}}</h2>
                </div>
                <div class="card-body p-0">
                    {{#hasliveclasses}}
                    <ul class="list-group list-group-flush iiidem-dash-list">
                        {{#liveclasses}}
                        <li class="list-group-item d-flex flex-wrap justify-content-between align-items-center gap-2">
                            <div>
                                {{#istoday}}<span class="badge bg-success me-1">{{#str}}today, core_calendar{{/str}}</span>{{/istoday}}
                                <span class="badge bg-info text-dark me-1">{{modlabel}}</span>
                                <strong>{{title}}</strong>
                                <div class="small text-muted">{{coursefullname}} · {{date}} {{time}}</div>
                            </div>
                            <a class="btn btn-sm btn-primary" href="{{{joinurl}}}">{{#str}}dashboardjoin, theme_iiidem2{{/str}}</a>
                        </li>
                        {{/liveclasses}}
                    </ul>
                    {{/hasliveclasses}}
                    {{^hasliveclasses}}
                    <p class="text-muted p-3 mb-0">{{#str}}dashboardnolive, theme_iiidem2{{/str}}</p>
                    {{/hasliveclasses}}
                </div>
            </section>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-lg-6">
            <section class="iiidem-dash-panel card shadow-sm h-100">
                <div class="card-header">
                    <h2 class="h5 mb-0">📢 {{#str}}dashboardnotifications, theme_iiidem2{{/str}}</h2>
                </div>
                <div class="card-body p-0">
                    {{#hasnotifications}}
                    <ul class="list-group list-group-flush iiidem-dash-list">
                        {{#notifications}}
                        <li class="list-group-item">
                            <span class="fa {{icon}} me-2 text-primary" aria-hidden="true"></span>
                            <a href="{{{url}}}">{{title}}</a>
                            <div class="small text-muted">{{meta}}{{#date}} · {{date}}{{/date}}</div>
                        </li>
                        {{/notifications}}
                    </ul>
                    {{/hasnotifications}}
                    {{^hasnotifications}}
                    <p class="text-muted p-3 mb-0">{{#str}}dashboardannouncements_none, theme_iiidem2{{/str}}</p>
                    {{/hasnotifications}}
                </div>
            </section>
        </div>

        <div class="col-lg-6">
            <section class="iiidem-dash-panel card shadow-sm h-100">
                <div class="card-header">
                    <h2 class="h5 mb-0">📝 {{#str}}dashboardrecentactivity, theme_iiidem2{{/str}}</h2>
                </div>
                <div class="card-body p-0">
                    {{#hasrecentactivity}}
                    <ul class="list-group list-group-flush iiidem-dash-list">
                        {{#recentactivity}}
                        <li class="list-group-item">
                            <span class="fa {{icon}} me-2 text-secondary" aria-hidden="true"></span>
                            <a href="{{{url}}}">{{title}}</a>
                            <div class="small text-muted">{{meta}}{{#date}} · {{date}}{{/date}}</div>
                        </li>
                        {{/recentactivity}}
                    </ul>
                    {{/hasrecentactivity}}
                    {{^hasrecentactivity}}
                    <p class="text-muted p-3 mb-0">{{#str}}dashboardnorecent, theme_iiidem2{{/str}}</p>
                    {{/hasrecentactivity}}
                </div>
            </section>
        </div>
    </div>

</div>
