<section class="iiidem-course-section iiidem-course-instructors">
    <div class="container">
        <header class="iiidem-course-section__header">
            <h2 class="iiidem-course-section__title">{{#str}}courseinstructorsheading, theme_iiidem2{{/str}}</h2>
        </header>

        <div class="career-grid">
            {{#instructordata}}
            <div class="career-card">
                <div class="career-image">
                    {{#profileurl}}
                    <a href="{{{profileurl}}}">
                        <img src="{{{image}}}" alt="{{name}}" class="instructor-photo">
                    </a>
                    {{/profileurl}}
                    {{^profileurl}}
                    <img src="{{{image}}}" alt="{{name}}" class="instructor-photo">
                    {{/profileurl}}
                </div>
                <div class="career-content">
                    <h3 class="iiidem-course-instructors__name">{{name}}</h3>
                    <span class="iiidem-course-instructors__role">{{role}}</span>
                    <p class="iiidem-course-instructors__bio">{{bio}}</p>
                </div>
            </div>
            {{/instructordata}}
        </div>
    </div>
</section>
