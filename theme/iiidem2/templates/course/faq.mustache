<section class="iiidem-course-section iiidem-course-faq">
    <div class="container">
        <header class="iiidem-course-section__header">
            <h2 class="iiidem-course-section__title">{{#str}}coursefaqheading, theme_iiidem2{{/str}}</h2>
        </header>

        <div class="accordion iiidem-accordion" id="courseFaqAccordion">
            {{#faqs}}
            <div class="accordion-item">
                <h3 class="accordion-header" id="faqheading{{id}}">
                    <button class="accordion-button collapsed"
                            type="button"
                            data-bs-toggle="collapse"
                            data-bs-target="#faqcollapse{{id}}"
                            aria-expanded="false"
                            aria-controls="faqcollapse{{id}}">
                        {{question}}
                    </button>
                </h3>

                <div id="faqcollapse{{id}}"
                     class="accordion-collapse collapse"
                     data-bs-parent="#courseFaqAccordion">
                    <div class="accordion-body">
                        {{{answer}}}
                    </div>
                </div>
            </div>
            {{/faqs}}

            {{^faqs}}
            <p class="iiidem-course-section__empty mb-0">{{#str}}coursefaqempty, theme_iiidem2{{/str}}</p>
            {{/faqs}}
        </div>
    </div>
</section>
