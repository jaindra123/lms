<section class="iiidem-course-section iiidem-course-curriculum">
    <div class="container">
        <header class="iiidem-course-section__header">
            <h2 class="iiidem-course-section__title">{{#str}}coursecontentheading, theme_iiidem2{{/str}}</h2>
            <p class="iiidem-course-section__subtitle">{{totalsections}} sections • {{totalactivities}} lectures</p>
        </header>

        {{#hascoursesummary}}
        <div class="iiidem-course-section__intro course-description">
            {{{ coursesummary }}}
        </div>
        {{/hascoursesummary}}

        <div class="iiidem-curriculum">
            <div class="accordion iiidem-accordion" id="courseAccordion">
                {{#sections}}
                <div class="accordion-item">
                    <h3 class="accordion-header" id="heading{{id}}">
                        <button class="accordion-button collapsed"
                                type="button"
                                data-bs-toggle="collapse"
                                data-bs-target="#collapse{{id}}"
                                aria-expanded="false"
                                aria-controls="collapse{{id}}">
                            <span class="iiidem-accordion__label">
                                <span class="iiidem-accordion__title">{{name}}</span>
                                <span class="iiidem-accordion__meta">{{#str}}coursecontentlectures, theme_iiidem2, {{activitycount}} {{/str}}</span>
                            </span>
                        </button>
                    </h3>

                    <div id="collapse{{id}}" class="accordion-collapse collapse" data-bs-parent="#courseAccordion">
                        <div class="accordion-body">
                            {{#activities}}
                            <div class="lecture-item">
                                <div class="d-flex justify-content-between align-items-center flex-wrap gap-2">
                                    <div class="iiidem-lecture-item__title">▶ {{title}}</div>
                                    {{#preview}}
                                    <div>
                                        {{#canpreviewcurriculum}}
                                        <button class="btn btn-sm btn-primary iiidem-curriculum-preview-btn" type="button"
                                                data-bs-toggle="collapse"
                                                data-bs-target="#preview{{id}}"
                                                aria-expanded="false"
                                                aria-controls="preview{{id}}"
                                                data-cmid="{{cmid}}"
                                                {{#trackcompletion}}data-trackcompletion="1"{{/trackcompletion}}
                                                {{^trackcompletion}}data-trackcompletion="0"{{/trackcompletion}}>
                                            {{previewlabel}}
                                        </button>
                                        {{/canpreviewcurriculum}}
                                        {{^canpreviewcurriculum}}
                                        {{#curriculumpreviewneedspayment}}
                                        <button type="button"
                                                class="btn btn-sm btn-primary iiidem-curriculum-pay-btn"
                                                data-bs-toggle="modal"
                                                data-bs-target="#iiidemPaymentRequiredModal"
                                                data-scroll-target="#iiidem-course-fee">
                                            {{previewlabel}}
                                        </button>
                                        {{/curriculumpreviewneedspayment}}
                                        {{^curriculumpreviewneedspayment}}
                                        {{#hasloginmodal}}
                                        <button type="button" class="btn btn-sm btn-primary"
                                                data-bs-toggle="modal"
                                                data-bs-target="#iiidemLoginModal">
                                            {{previewlabel}}
                                        </button>
                                        {{/hasloginmodal}}
                                        {{^hasloginmodal}}
                                        <a href="{{loginurl}}" class="btn btn-sm btn-primary">
                                            {{previewlabel}}
                                        </a>
                                        {{/hasloginmodal}}
                                        {{/curriculumpreviewneedspayment}}
                                        {{/canpreviewcurriculum}}
                                    </div>
                                    {{/preview}}
                                </div>

                                {{#canpreviewcurriculum}}
                                {{#haspreviewcontent}}
                                <div class="collapse mt-2" id="preview{{id}}"
                                     data-cmid="{{cmid}}"
                                     {{#trackcompletion}}data-trackcompletion="1"{{/trackcompletion}}
                                     {{^trackcompletion}}data-trackcompletion="0"{{/trackcompletion}}>
                                    <div class="card card-body">
                                        {{{previewcontent}}}
                                    </div>
                                </div>
                                {{/haspreviewcontent}}
                                {{/canpreviewcurriculum}}
                            </div>
                            {{/activities}}
                        </div>
                    </div>
                </div>
                {{/sections}}
            </div>
        </div>
    </div>
</section>
