<?xml version="1.0" encoding="UTF-8" ?>
<XMLDB PATH="local/coursefaq/db" VERSION="2026052000" COMMENT="Course FAQ plugin">

    <TABLES>

        <TABLE NAME="local_coursefaq" COMMENT="Stores course FAQs">
            <FIELDS>

                <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true" COMMENT="Primary key"/>
                
                <FIELD NAME="courseid" TYPE="int" LENGTH="10" NOTNULL="true" COMMENT="Course ID"/>
                
                <FIELD NAME="question" TYPE="text" NOTNULL="true" COMMENT="FAQ question"/>
                
                <FIELD NAME="answer" TYPE="text" NOTNULL="true" COMMENT="FAQ answer"/>

            </FIELDS>

            <KEYS>
                <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
            </KEYS>

        </TABLE>

    </TABLES>

</XMLDB>