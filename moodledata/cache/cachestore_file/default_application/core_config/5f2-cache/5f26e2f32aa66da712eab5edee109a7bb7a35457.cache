a:38:{s:7:"address";s:40:" Sector-13, Dwarka, Delhi, 110078, India";s:15:"backgroundimage";s:0:"";s:10:"brandcolor";s:0:"";s:13:"copyrighttext";s:39:"Copyright ECI 2026. All Rights Reserved";s:11:"description";s:466:"The Election Commission of India has set up the India International Institute of Democracy & Election Management (IIIDEM) as its advance training and resources wing. Springing from the realization of modern India’s founding fathers and constitutions makers that free, fair, credible and professionally managed elections are the bedrock of democracy, IIIDEM is an initiative of the Commission for fulfilling its high aspiration on democracy and election management.";s:5:"email";s:45:" +91-11-25303512 it[-]iiidem[@]eci[.]gov[.]in";s:11:"facebookurl";s:54:"https://www.facebook.com/profile.php?id=61577738428374";s:10:"footerlogo";s:29:"/iiidem-white-logo-footer.png";s:10:"headerlogo";s:22:"/iiidem_about_logo.PNG";s:12:"instagramurl";s:41:"https://www.instagram.com/iiidem_official";s:20:"loginbackgroundimage";s:0:"";s:5:"phone";s:15:"+91-11-25303512";s:6:"preset";s:12:"default.scss";s:11:"presetfiles";s:0:"";s:14:"quicklink1text";s:8:"About Us";s:13:"quicklink1url";s:1:"#";s:4:"scss";s:0:"";s:7:"scsspre";s:0:"";s:13:"slidebtntext1";s:0:"";s:13:"slidebtntext2";s:0:"";s:13:"slidebtntext3";s:0:"";s:12:"slidebtnurl1";s:0:"";s:12:"slidebtnurl2";s:0:"";s:12:"slidebtnurl3";s:0:"";s:10:"slidedesc1";s:24:"<p>Slide Description</p>";s:10:"slidedesc2";s:25:"<p>Slide2 Description</p>";s:10:"slidedesc3";s:18:"Slide3 Description";s:11:"slideimage1";s:18:"/1757917528137.jpg";s:11:"slideimage2";s:18:"/1757917399285.jpg";s:11:"slideimage3";s:0:"";s:11:"slidetitle1";s:7:"Slide 1";s:11:"slidetitle2";s:6:"Slide2";s:11:"slidetitle3";s:6:"Slide3";s:8:"themerev";s:10:"1780375708";s:10:"twitterurl";s:30:"https://x.com/IIIDEM_Official/";s:15:"unaddableblocks";s:45:"navigation,settings,course_list,section_links";s:7:"version";s:10:"2024100707";s:10:"youtubeurl";s:40:"https://www.youtube.c